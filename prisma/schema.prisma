generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model allocationtype {
  id        Int      @id @default(autoincrement())
  name      String   @unique(map: "AllocationType_name_key")
  code      String   @unique(map: "AllocationType_code_key")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model book {
  id             Int              @id @default(autoincrement())
  name           String
  description    String           @db.Text
  stock          Int
  imageurl       String
  userId         Int
  status         book_status      @default(PENDING)
  planSentAt     DateTime         @default(now())
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  canceledAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  user           user             @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Book_userId_fkey")
  bookcategories bookcategories[]
  commentbook    commentbook[]
  peminjaman     peminjaman[]

  @@index([userId], map: "Book_userId_fkey")
}

model bookcategories {
  bookId     Int
  categoryId Int
  book       book     @relation(fields: [bookId], references: [id], onDelete: Cascade, map: "BookCategories_bookId_fkey")
  category   category @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "BookCategories_categoryId_fkey")

  @@id([categoryId, bookId])
  @@index([bookId], map: "BookCategories_bookId_fkey")
}

model category {
  id             Int              @id @default(autoincrement())
  name           String
  bookcategories bookcategories[]
}

model comment {
  id        Int      @id @default(autoincrement())
  userId    Int
  body      String   @db.Text
  postId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model commentbook {
  id          Int      @id @default(autoincrement())
  userId      Int
  bookId      Int
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  book        book     @relation(fields: [bookId], references: [id], onDelete: Cascade, map: "CommentBook_bookId_fkey")
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "CommentBook_userId_fkey")

  @@index([bookId], map: "CommentBook_bookId_fkey")
  @@index([userId], map: "CommentBook_userId_fkey")
}

model commentlike {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model content {
  id              Int               @id @default(autoincrement())
  title           String
  description     String?
  thumbnailUrl    String
  videoUrl        String
  duration        Int?
  views           Int               @default(0)
  publishedAt     DateTime          @default(now())
  uploaderId      Int
  user            user              @relation(fields: [uploaderId], references: [id], onDelete: NoAction, map: "Content_uploaderId_fkey")
  playlistcontent playlistcontent[]

  @@index([uploaderId], map: "Content_uploaderId_fkey")
}

model errorlog {
  id           Int      @id @default(autoincrement())
  errorMessage String   @db.Text
  stackTrace   String?  @db.Text
  createdAt    DateTime @default(now())
}

model infaq {
  id                 String   @id
  userId             Int
  amount             Float
  status             String   @default("pending")
  orderId            String   @unique(map: "Infaq_orderId_key")
  redirectUrl        String   @default("https://www.google.com")
  allocationTypeCode String
  paymentType        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  user               user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Infaq_userId_fkey")

  @@index([userId], map: "Infaq_userId_fkey")
}

model kegiatan {
  id        Int      @id @default(autoincrement())
  title     String
  file1     String?
  file2     String?
  file3     String?
  userId    Int
  score     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Kegiatan_userId_fkey")

  @@index([userId], map: "Kegiatan_userId_fkey")
}

model news {
  id        Int      @id @default(autoincrement())
  title     String
  subTitle  String
  author    String
  imageUrl  String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model notification {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  data      String   @db.LongText
  userId    Int
  imageUrl  String?
  createdAt DateTime @default(now())
  updateAt  DateTime
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Notification_userId_fkey")

  @@index([userId], map: "Notification_userId_fkey")
}

model officeaddress {
  id        Int      @id @default(autoincrement())
  name      String
  address   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model peminjaman {
  id                Int               @id @default(autoincrement())
  bookId            Int
  userId            Int
  status            peminjaman_status @default(PENDING)
  submissionDate    DateTime          @default(now())
  deadlineDate      DateTime
  plannedPickUpDate DateTime
  actualPickUpDate  DateTime?
  returnDate        DateTime?
  cancelDate        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  book              book              @relation(fields: [bookId], references: [id], onDelete: Cascade, map: "Peminjaman_bookId_fkey")
  user              user              @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Peminjaman_userId_fkey")

  @@index([bookId], map: "Peminjaman_bookId_fkey")
  @@index([userId], map: "Peminjaman_userId_fkey")
}

model playlist {
  id              Int               @id @default(autoincrement())
  title           String
  description     String?
  playlistcontent playlistcontent[]
}

model playlistcontent {
  contentId  Int
  playlistId Int
  order      Int
  content    content  @relation(fields: [contentId], references: [id], onDelete: NoAction, map: "PlaylistContent_contentId_fkey")
  playlist   playlist @relation(fields: [playlistId], references: [id], onDelete: NoAction, map: "PlaylistContent_playlistId_fkey")

  @@id([contentId, playlistId])
  @@unique([playlistId, order], map: "PlaylistContent_playlistId_order_key")
}

model post {
  id        Int      @id @default(autoincrement())
  userId    Int
  body      String   @db.Text
  createdAt DateTime @default(now())
  updateAt  DateTime
}

model postdislike {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model postlike {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model profile {
  id               Int       @id @default(autoincrement())
  nama             String?
  bio              String?
  photo            String?
  namaIstri        String?
  namaAnak         String?
  tahunMasukKuttab Int?
  forgotCode       String?   @unique
  forgotExpiredAt  DateTime?
  userId           Int       @unique(map: "Profile_userId_key")
  namaKuttab       String?
  user             user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Profile_userId_fkey")
}

model question {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String?  @db.Text
  isAnswer  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model reply {
  id        Int      @id @default(autoincrement())
  userId    Int
  body      String   @db.Text
  commentId Int
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model replylike {
  id        Int      @id @default(autoincrement())
  userId    Int
  replyId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model report {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int?
  commentId Int?
  replyId   Int?
  reason    String   @db.Text
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}

model user {
  id                           Int            @id @default(autoincrement())
  username                     String
  email                        String         @unique(map: "User_email_key")
  password                     String
  isVerified                   Boolean        @default(false)
  verificationCode             String?
  totalScoreYear               Int?           @default(0)
  totalScoreMonth              Int?           @default(0)
  totalScoreDay                Int?           @default(0)
  fcmToken                     String?
  role                         user_role?     @default(USER)
  deleteAccountVerficationCode String?
  deleteReason                 String?        @db.Text
  isActive                     Boolean        @default(true)
  alms                         alms[]
  book                         book[]
  commentbook                  commentbook[]
  content                      content[]
  infaq                        infaq[]
  kegiatan                     kegiatan[]
  notification                 notification[]
  peminjaman                   peminjaman[]
  profile                      profile?
}

model alms {
  id                 Int      @id @default(autoincrement())
  userId             Int
  amount             Float
  status             String   @default("pending")
  allocationTypeCode String
  evidenceImageUrl   String?
  message            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model userdeleted {
  id           Int      @id @default(autoincrement())
  email        String
  deleteReason String?  @db.Text
  deletedAt    DateTime @default(now())
}

enum peminjaman_status {
  PENDING
  ALLOWED
  TAKEN
  RETURNED
  CANCELLED
}

enum book_status {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum user_role {
  ADMIN
  USER
}
