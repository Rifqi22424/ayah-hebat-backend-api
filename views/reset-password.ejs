<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Ayah Hebat</title>
    <style>
      /* --- Gaya Asli dari Contoh Anda --- */
      body {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
        text-align: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        flex-direction: column;
        color: #333;
      }
      .container {
        background-color: white;
        padding: 2.5rem 3rem;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        width: 400px; /* Sedikit lebih lebar untuk form */
        max-width: 90%;
        animation: fadeIn 1s ease-in-out;
      }
      h1 {
        font-size: 2.2rem;
        margin-bottom: 1.5rem; /* Sedikit lebih banyak ruang */
        color: #2c3e50;
      }
      .logo {
        font-size: 2.5rem;
        font-weight: bold;
        color: #3498db;
        margin-bottom: 1rem;
      }
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      
      /* --- Gaya Tambahan untuk Form (Pendekatan Baru) --- */
      .form-group {
        margin-bottom: 1.25rem;
        text-align: left;
      }
      .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: #555;
      }
      .form-group input {
        width: 100%;
        padding: 0.75rem;
        box-sizing: border-box; 
        border: 1px solid #ccc;
        border-radius: 5px;
        font-size: 1rem;
      }
      .btn {
        width: 100%;
        padding: 0.85rem;
        border: none;
        border-radius: 5px;
        background-color: #3498db; /* Menyamakan warna dengan logo */
        color: white;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition: background-color 0.3s ease;
      }
      .btn:hover {
        background-color: #2980b9;
      }
      .btn:disabled {
        background-color: #cccccc;
        cursor: not-allowed;
      }
      .error-box {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
        padding: 1rem;
        border-radius: 5px;
        margin-bottom: 1.5rem;
        text-align: center;
      }
    </style>
  </head>
  <body>

    <div class="container">
      <div class="logo">Ayah Hebat</div>
      <h1>Atur Ulang Password</h1>

      <%# Step 5: Tampilkan error box merah jika kode invalid/expired %>
      <% if (error) { %>
        <div class="error-box">
          <%= error %>
        </div>
      <% } %>

      <%# Form submit ke Step 6 %>
      <form action="/auth/reset-password" method="POST">
        
        <%# Kirim kodenya kembali ke server secara tersembunyi %>
        <input type="hidden" name="code" value="<%= code %>" />

        <div class="form-group">
          <label for="newPassword">Password Baru</label>
          <input 
            type="password" 
            id="newPassword" 
            name="newPassword" 
            required 
            <%# Step 5: Nonaktifkan form jika ada error %>
            <%= error ? 'disabled' : '' %> 
          />
        </div>

        <div class="form-group">
          <label for="newConfirmationPassword">Konfirmasi Password Baru</label>
          <input 
            type="password" 
            id="newConfirmationPassword" 
            name="newConfirmationPassword" 
            required 
            <%= error ? 'disabled' : '' %>
          />
        </div>

        <button 
          type="submit" 
          class="btn" 
          <%# Step 5: Nonaktifkan tombol submit jika ada error %>
          <%= error ? 'disabled' : '' %>
        >
          Reset Password
        </button>
      </form>
    </div>

  </body>
</html>